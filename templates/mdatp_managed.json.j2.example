{
  "antivirusEngine": {
    "enableRealTimeProtection": false,
    "passiveMode": true,
    "threatTypeSettings": [
      {
        "key": "potentially_unwanted_application",
        "value": "block"
      },
      {
        "key": "archive_bomb",
        "value": "audit"
      }
    ]
  },
  "cloudService": {
    "automaticDefinitionUpdateEnabled": true,
    "automaticSampleSubmissionConsent": "safe",
    "enabled": true
  }
}
